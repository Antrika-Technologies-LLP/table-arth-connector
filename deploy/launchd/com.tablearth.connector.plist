<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tablearth.connector</string>
    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/tac-agent</string>
        <string>-config</string>
        <string>/usr/local/etc/table-arth-connector/config.yaml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>5</integer>
    <key>StandardOutPath</key>
    <string>/usr/local/var/log/table-arth-connector.log</string>
    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/table-arth-connector.log</string>
</dict>
</plist>
